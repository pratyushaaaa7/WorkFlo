{
  "expo": {
    "name": "Thuhroh",
    "slug": "Thuhroh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoLight.png",
    "scheme": "thuhroh",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.app.thuhroh"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoLight.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.app.thuhroh",
      "googleServicesFile": "./android/app/google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logoIconThuhroh.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashScreenLight.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/images/splashScreenDark.png",
            "backgroundColor": "#0D0D0D"
          }
        }
      ],
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52f1329e-b60c-4d03-877d-18c4f35e0057"
      }
    }
  }
}
