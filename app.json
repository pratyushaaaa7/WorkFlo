{
  "expo": {
    "name": "BITA",
    "slug": "WTech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bita.png",
    "scheme": "wtech",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.WTech"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/bita.png",
        "backgroundColor": "#020618"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.WTech"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/bita.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bita.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020618"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1e200b30-6c2f-48a1-aed9-06edca468b0b"
      }
    }
  }
}
